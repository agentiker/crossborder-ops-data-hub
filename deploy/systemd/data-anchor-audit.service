[Unit]
Description=审计哈希链每日锚定（链尾外发飞书留痕 + 内联完整性校验）
After=network-online.target
OnFailure=data-onfailure@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/code/crossborder-ops-data-hub
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/.local/bin/uv run python -m flows.anchor_audit_chain
TimeoutStartSec=300
