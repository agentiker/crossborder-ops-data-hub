[Unit]
Description=TikTok 广告消耗同步（结算口径）
After=network-online.target
OnFailure=data-onfailure@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/code/crossborder-ops-data-hub
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/.local/bin/uv run python -m flows.sync_ad_spend
# 单次最长 10 分钟，挂死自动杀
TimeoutStartSec=600
