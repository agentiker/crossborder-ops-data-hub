[Unit]
Description=TikTok 库存同步
After=network-online.target
OnFailure=data-onfailure@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/code/crossborder-ops-data-hub
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/.local/bin/uv run python -m flows.sync_inventory
# 单次最长 10 分钟，挂死自动杀
TimeoutStartSec=600
