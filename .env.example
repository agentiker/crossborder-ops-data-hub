# 数据库配置
DB__HOST=localhost
DB__PORT=3306
DB__USER=root
DB__PASSWORD=your_password
DB__DATABASE=ai_data_pipeline

# TikTok Shop配置
TIKTOK__APP_KEY=your_app_key
TIKTOK__APP_SECRET=your_app_secret
TIKTOK__BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK__AUTH_BASE_URL=https://auth.tiktok-shops.com
# 回调地址（redirect_uri）以 TTS 后台登记值为准，本地无需配置；
# 公网入口为 nginx 反代： https://你的域名/auth/callback/tiktok（见 deploy/nginx.conf）

# 对外 HTTP 接口配置（供 openclaw skill 本机调用）
API__HOST=127.0.0.1
API__PORT=8000
# 内部令牌：skill 调用 /api/data 时需在 X-Internal-Token 头携带，生成示例：python -c "import secrets;print(secrets.token_urlsafe(32))"
API__INTERNAL_TOKEN=

# Prefect配置（可选，默认使用本地SQLite）
# PREFECT_API_URL=http://127.0.0.1:4200/api

# Web 对话端 LLM Provider（plan/15 Phase A，可配置：国外/国内通用）
# provider=openai 覆盖 OpenAI 兼容族（DeepSeek/通义千问/智谱GLM/Kimi/豆包/OpenAI…），
#   切换只换 base_url+api_key+model；provider=anthropic 走 Claude（/v1/messages）。
# 示例（DeepSeek）：LLM__PROVIDER=openai  LLM__BASE_URL=https://api.deepseek.com/v1  LLM__MODEL=deepseek-chat
# 示例（通义千问）：LLM__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM__MODEL=qwen-plus
LLM__PROVIDER=openai
LLM__BASE_URL=
LLM__API_KEY=
LLM__MODEL=
# LLM__TEMPERATURE=0.3
# LLM__MAX_TOOL_STEPS=6

