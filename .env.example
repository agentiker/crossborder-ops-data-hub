# Crossborder Ops Data Hub —— .env 模板
# 复制为 .env 后逐项填写。占位符 <...> 必须替换；标「可选」的留空走默认。
# 字段与 core/config.py 的 Settings 一一对应；嵌套用双下划线 __。
# 完整投产步骤见 docs/production-deployment.md，openclaw 网关侧配置见 docs/openclaw-setup.md。
# ⚠️ 本文件入库，严禁写真实密钥；密钥生成命令见各段注释 / 手册 §5.2。

# ── 数据库 ──
DB__HOST=127.0.0.1
DB__PORT=3306
DB__USER=appuser
DB__PASSWORD=<强随机密码>
DB__DATABASE=ai_data_pipeline

# ── TikTok Shop（生产 app）──
TIKTOK__APP_KEY=<生产 app_key>
TIKTOK__APP_SECRET=<生产 app_secret>
TIKTOK__BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK__AUTH_BASE_URL=https://auth.tiktok-shops.com
# OAuth 回调地址不在此配，去 Partner Center 登记 https://<域名>/auth/callback/tiktok
# 出口 IP 须加入 TikTok 白名单（生产机直连出口 IP，见 docs/ops-runbook.md 排坑库）

# ── 内部 API（供 openclaw / MCP 本机调用）──
API__HOST=127.0.0.1                 # 永远回环，别 0.0.0.0；公网隧道不放行 /api/data/*、/mcp
API__PORT=8000
# 内部令牌：openclaw 调 /api/data、/mcp 时在 X-Internal-Token 头携带。
# 须与 openclaw env.vars.DATA_HUB_TOKEN 完全一致（见 docs/openclaw-setup.md MCP 节）。
# 生成：python3 -c "import secrets;print(secrets.token_urlsafe(32))"
API__INTERNAL_TOKEN=<secrets#1>

# ── 看板/报告签名链接（飞书 H5）──
DASHBOARD__LINK_SECRET=<secrets#2>          # HMAC-SHA256 密钥；未配则验签一律失败
DASHBOARD__PUBLIC_BASE_URL=https://<域名>   # 隧道公网根，签发链接用
# DASHBOARD__TOKEN_TTL_SECONDS=1800         # 可选，默认 30 分钟

# ── 飞书 OAuth 网页免登（/app 登录、bootstrap）──
# 独立于 openclaw 的 lark.secrets.json！按 account_id（租户主键）索引，JSON 串。
# 单租户也建议用 apps 形式，account_id 须与 TENANCY__DEFAULT_ACCOUNT 一致。
FEISHU_OAUTH__APPS={"ecom-app-gtl":{"app_id":"cli_xxx","app_secret":"<飞书 app_secret>"}}
FEISHU_OAUTH__SESSION_SECRET=<secrets#3>    # 登录态 cookie 的 HMAC 密钥（独立于 LINK_SECRET）
FEISHU_OAUTH__COOKIE_SECURE=true            # 生产 HTTPS 必须 true
# FEISHU_OAUTH__OAUTH_SCOPE=contact:user.base:readonly  # 默认即此，须在飞书后台开通并发版
# FEISHU_OAUTH__ENFORCE_DIALOG_AUTHZ=false  # 对话登记闸灰度开关，默认 false（仅记日志）

# ── 多租户拓扑（部署级事实源，与隧道放行的子域名同源管理）──
# 单客户独立部署：DEFAULT_ACCOUNT 覆盖成本机租户，让 board 冷登录/token 授权/MCP
# 无头查询的回落全对齐到飞书 agent 的同一 account（默认 ecom-app 仅适配 hp 存量库）。
# ⚠️ DEFAULT_ACCOUNT、FEISHU_OAUTH__APPS 的键、HOST_TO_ACCOUNT 的 value 三处必须一致，
#    否则 bootstrap 会落错租户（详见手册 §5.3 与 scripts/preflight.py 的对齐校验）。
TENANCY__DEFAULT_ACCOUNT=ecom-app-gtl
TENANCY__HOST_TO_ACCOUNT={"<域名>":"ecom-app-gtl"}
# TENANCY__PUBLIC_BASE_URL={"ecom-app-gtl":"https://<域名>"}   # 可选，多租户报告链接用

# ── 马帮 ERP 成本抓取（flows/sync_mabang_costs，无头浏览器登录抓统一成本价入 product_costs）──
# 凭证仅用于登录，不落库/不进日志。MABANG__ACCOUNT 为空则回落 TENANCY__DEFAULT_ACCOUNT。
# 部署后须一次性 `uv run playwright install chromium`。
MABANG__USER=<马帮登录手机号>
MABANG__PASSWORD=<马帮登录密码>
# MABANG__ACCOUNT=ecom-app-gtl   # 成本归属租户；空则用 DEFAULT_ACCOUNT

# ── Web 对话 LLM Provider（plan/15，国内外通用）──
# provider=openai 覆盖 OpenAI 兼容族（DeepSeek/通义/智谱GLM/Kimi/豆包…），切换只换 base_url+key+model；
# provider=anthropic 走 Claude 协议（/v1/messages）。
# ⚠️ Anthropic 兼容中转站（如 api.agent0101.com）也填 anthropic，填 glm 会抛错 500（见 ops-runbook）。
LLM__PROVIDER=openai
LLM__BASE_URL=https://api.deepseek.com/v1
LLM__API_KEY=<llm key>
LLM__MODEL=deepseek-chat
# LLM__TEMPERATURE=0.3
# LLM__MAX_TOOL_STEPS=6

# ── openclaw 直投（监控告警 0 经 LLM 直发飞书；systemd PATH 无 nvm，必须绝对路径）──
# deploy.sh 探测到会自动写入；手动填：~/.nvm/versions/node/vXX/bin/openclaw
OPENCLAW_BIN=/home/<user>/.nvm/versions/node/vXX.XX.X/bin/openclaw

# ── 上线合规三件套（生产必配；密钥须存备份之外，丢 key = 不可恢复）──
# Fernet key（44 字符，platform_tokens 透明加密）：
#   uv run python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=<Fernet key>
# 每日 mysqldump 加密备份 GPG 对称口令：openssl rand -base64 32
BACKUP_GPG_PASSPHRASE=<openssl rand 口令>
# 审计哈希链每日锚定（发飞书运维群留痕）；空库阶段可先 false，正式运营前置 true。
AUDIT_ANCHOR_ENABLED=true
AUDIT_ANCHOR_ACCOUNT=<飞书 openclaw account 键，如 main-app>
AUDIT_ANCHOR_OPEN_ID=<运维飞书 open_id ou_xxx>   # 同 notify-failure 收件人
# 补货采购单运维抄送（三者全配才启用）：把数据源租户的全量补货单用运维 app 凭证抄送一份。
#   投递凭证/坐标系（运维 app，per-app open_id 必须配对）：main-app
#   运维 open_id（运维 app 坐标系，可从 ~/.openclaw/openclaw.json 的 main-app.allowFrom 取）
#   数据来源租户（算补货用，客户租户）：ecom-app-gtl（prod）/ ecom-app（hp）
REPLENISHMENT_CC_ACCOUNT=main-app
REPLENISHMENT_CC_OPEN_ID=<运维 open_id ou_xxx>
REPLENISHMENT_CC_SOURCE_ACCOUNT=ecom-app-gtl

# ── 可选阈值（告警/补货/利润/费率等，均有默认值，无需配）──
# 要调见 core/config.py 注释：FULFILLMENT_WARNING_HOURS / STOCK_COVER_* /
#   FEE_RATE_* / HOTSELL_DAILY_UNITS_THRESHOLD / REPLENISH_* / IDR_TO_RMB 等。
